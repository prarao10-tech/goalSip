    tbRows+='<td>'+fmt(y.reqMon,sym)+'</td>';
    tbRows+='<td>'+fmt(y.reqAnn,sym)+'</td>';
    tbRows+='<td>'+hA+'</td>';
    tbRows+='<td>'+hP+'</td>';
    tbRows+='<td style="text-align:left;min-width:160px">'+wdCell+'</td>';
    tbRows+='</tr>';

    // Dedicated withdrawal detail row (highlighted, full width)
    if(y.wdThisYear.length){
      var totalCols=goalData.length*2+8; // year + 2 per goal + 6 summary cols + wd col
      tbRows+='<tr class="wd-row">'+
        '<td colspan="'+totalCols+'" style="text-align:left;padding:6px 16px;font-size:11px;border-left:3px solid var(--wd)">'+
        '<strong style="color:var(--wd)">💸 Withdrawal Event — Year '+y.year+'</strong>&nbsp;&nbsp;'+
        y.wdThisYear.map(function(w){
          return '<span style="margin-right:16px"><strong>'+w.goal+'</strong>'+(w.note?' ('+w.note+')':'')+
            ' → FV at withdrawal: <strong>'+fmt(w.fv,sym)+'</strong></span>';
        }).join('')+
        '<span style="float:right;color:var(--wd);font-family:\'JetBrains Mono\',monospace">Total outflow this year: '+fmt(y.totalWdAmt,sym)+'</span>'+
        '</td></tr>';
