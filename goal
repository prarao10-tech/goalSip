<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIP Goal Planner · Financial Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root[data-theme="dark"]{
  --bg:#0d1117;--surface:#161b22;--surface2:#1c2128;--surface3:#21262d;
  --border:#30363d;--border2:#3d444d;
  --accent:#2ea043;--accent-h:#3fb950;--accent2:#388bfd;--accent3:#f78166;--accent4:#e3b341;
  --text:#e6edf3;--text2:#8b949e;--text3:#484f58;
  --danger:#f85149;--success:#2ea043;--success-t:#3fb950;
  --wd:#a78bfa;--wd-bg:rgba(167,139,250,.12);--wd-border:rgba(167,139,250,.3);
  --badge-bg:rgba(46,160,67,.15);--badge-b:rgba(46,160,67,.3);--shadow:rgba(0,0,0,.3);
}
:root[data-theme="light"]{
  --bg:#f6f8fa;--surface:#fff;--surface2:#f6f8fa;--surface3:#eaeef2;
  --border:#d0d7de;--border2:#c6cdd5;
  --accent:#1a7f37;--accent-h:#2da44e;--accent2:#0969da;--accent3:#d1242f;--accent4:#9a6700;
  --text:#1f2328;--text2:#636c76;--text3:#9198a1;
  --danger:#d1242f;--success:#1a7f37;--success-t:#1a7f37;
  --wd:#7c3aed;--wd-bg:rgba(124,58,237,.08);--wd-border:rgba(124,58,237,.25);
  --badge-bg:rgba(26,127,55,.1);--badge-b:rgba(26,127,55,.25);--shadow:rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Inter',-apple-system,sans-serif;font-size:14px;line-height:1.5;min-height:100vh;transition:background .25s,color .25s}
.container{max-width:1280px;margin:0 auto;padding:0 24px 60px}
header{background:var(--surface);border-bottom:1px solid var(--border);padding:0 24px;position:sticky;top:0;z-index:100;box-shadow:0 1px 3px var(--shadow)}
.header-inner{max-width:1280px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:56px;gap:16px}
.brand{display:flex;align-items:center;gap:8px;text-decoration:none}
.brand-icon{width:32px;height:32px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.brand-name{font-size:15px;font-weight:600;color:var(--text)}.brand-name span{color:var(--accent)}
.header-right{display:flex;align-items:center;gap:12px}
.header-sub{font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace}
.theme-toggle{background:var(--surface2);border:1px solid var(--border);border-radius:20px;cursor:pointer;padding:4px 10px;display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);font-family:'Inter',sans-serif;transition:all .2s;white-space:nowrap}
.theme-toggle:hover{background:var(--surface3);border-color:var(--border2);color:var(--text)}
.page-header{padding:28px 0 20px}
.page-title{font-size:22px;font-weight:600;color:var(--text);letter-spacing:-.4px;margin-bottom:4px}
.page-subtitle{font-size:13px;color:var(--text2)}
.settings-panel{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px 20px;margin-bottom:24px;display:flex;align-items:flex-end;gap:24px;flex-wrap:wrap}
.settings-panel-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin-bottom:12px;width:100%}
.settings-field{display:flex;flex-direction:column;gap:4px}
.settings-label{font-size:12px;font-weight:500;color:var(--text2)}
.settings-input{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;padding:6px 10px;width:130px;outline:none;transition:border-color .15s,box-shadow .15s}
.settings-input:focus{border-color:var(--accent2);box-shadow:0 0 0 3px rgba(56,139,253,.15)}
.settings-desc,.hint-text{font-size:11px;color:var(--text3)}
.hint-text{font-family:'JetBrains Mono',monospace;margin-top:3px;min-height:14px}
.settings-divider{width:1px;height:48px;background:var(--border);align-self:center;flex-shrink:0}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.section-title{font-size:14px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:7px}
.section-title .dot{width:7px;height:7px;border-radius:50%;background:var(--accent);flex-shrink:0}
.section-badge{font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text3);background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:2px 8px}
/* GOAL CARDS */
.goals-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(400px,1fr));gap:14px;margin-bottom:18px}
.goal-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px;transition:border-color .2s,box-shadow .2s,opacity .2s;animation:cardIn .25s ease both}
.goal-card.disabled{opacity:.45;pointer-events:none}
.goal-card.disabled .goal-toggle-area{pointer-events:all}
@keyframes cardIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.goal-card:hover{border-color:var(--border2);box-shadow:0 2px 8px var(--shadow)}
.goal-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.goal-card-left{display:flex;align-items:center;gap:8px}
.goal-card-right{display:flex;align-items:center;gap:8px}
.goal-number{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent);font-weight:500;letter-spacing:.5px;background:var(--badge-bg);border:1px solid var(--badge-b);padding:2px 8px;border-radius:20px}
.toggle-wrap{display:flex;align-items:center;gap:5px;cursor:pointer;user-select:none}
.toggle-label{font-size:11px;font-weight:500;color:var(--text2)}
.toggle-sw{position:relative;width:32px;height:18px;flex-shrink:0}
.toggle-sw input{opacity:0;width:0;height:0;position:absolute}
.toggle-track{position:absolute;inset:0;background:var(--border2);border-radius:18px;transition:background .2s}
.toggle-thumb{position:absolute;top:3px;left:3px;width:12px;height:12px;background:#fff;border-radius:50%;transition:transform .2s}
.toggle-sw input:checked+.toggle-track{background:var(--accent)}
.toggle-sw input:checked~.toggle-thumb{transform:translateX(14px)}
.remove-btn{background:none;border:1px solid var(--border);color:var(--text3);cursor:pointer;width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:12px;line-height:1}
.remove-btn:hover{border-color:var(--danger);color:var(--danger);background:rgba(248,81,73,.08)}
.goal-name-input{width:100%;background:transparent;border:none;border-bottom:1px solid var(--border);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;font-weight:600;padding:4px 0 8px;margin-bottom:14px;outline:none;transition:border-color .15s}
.goal-name-input:focus{border-color:var(--accent2)}
.goal-name-input::placeholder{color:var(--text3);font-weight:400}
.goal-fields{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.field-group{display:flex;flex-direction:column;gap:4px}
.field-label{font-size:11px;font-weight:500;color:var(--text2)}
.field-input{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;padding:6px 9px;outline:none;transition:border-color .15s,box-shadow .15s;width:100%}
.field-input:focus{border-color:var(--accent2);box-shadow:0 0 0 3px rgba(56,139,253,.12)}
/* OPTIONAL SECTIONS (lumpsum / withdrawals) */
.opt-section{margin-top:12px;padding-top:12px;border-top:1px dashed var(--border)}
.opt-section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0}
.opt-section-title{font-size:11px;font-weight:600;color:var(--text2);display:flex;align-items:center;gap:5px}
.opt-fields{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
.opt-fields.hidden{display:none}
.opt-note{font-size:10px;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-top:4px;grid-column:span 2}
/* WITHDRAWAL LIST */
.wd-list{margin-top:10px;display:flex;flex-direction:column;gap:8px}
.wd-item{background:var(--wd-bg);border:1px solid var(--wd-border);border-radius:8px;padding:10px 12px;position:relative;animation:cardIn .2s ease both}
.wd-item-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.wd-item-label{font-size:11px;font-weight:600;color:var(--wd);letter-spacing:.3px}
.wd-item-fields{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.wd-field-label{font-size:10px;font-weight:500;color:var(--text3);margin-bottom:3px}
.wd-input{background:var(--surface);border:1px solid var(--border);border-radius:5px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;padding:5px 8px;outline:none;transition:border-color .15s;width:100%}
.wd-input:focus{border-color:var(--wd);box-shadow:0 0 0 2px rgba(124,58,237,.12)}
.wd-add-btn{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:500;color:var(--wd);background:var(--wd-bg);border:1px dashed var(--wd-border);border-radius:6px;padding:5px 10px;cursor:pointer;transition:all .15s;margin-top:8px;font-family:'Inter',sans-serif}
.wd-add-btn:hover{background:var(--wd-bg);border-style:solid;opacity:.85}
.wd-remove-btn{background:none;border:none;color:var(--text3);cursor:pointer;font-size:11px;padding:2px 4px;border-radius:4px;transition:color .15s}
.wd-remove-btn:hover{color:var(--danger)}
/* BUTTONS */
.btn{font-family:'Inter',sans-serif;font-size:13px;font-weight:500;border:none;cursor:pointer;border-radius:6px;padding:8px 16px;transition:all .15s;display:inline-flex;align-items:center;gap:6px;line-height:1}
.btn-ghost{background:var(--surface2);color:var(--text2);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--surface3);color:var(--text);border-color:var(--border2)}
.btn-primary{background:var(--accent);color:#fff;border:1px solid transparent}
.btn-primary:hover{background:var(--accent-h);box-shadow:0 2px 8px rgba(46,160,67,.3)}
.btn-export{background:var(--accent2);color:#fff;border:1px solid transparent}
.btn-export:hover{opacity:.88;box-shadow:0 2px 8px rgba(9,105,218,.3)}
.btn-actions{display:flex;gap:10px;margin-bottom:32px;flex-wrap:wrap}
/* RESULTS */
.divider{height:1px;background:var(--border);margin:28px 0}
.results-section{display:none}.results-section.visible{display:block}
.export-bar{display:flex;justify-content:flex-end;align-items:center;gap:10px;margin-bottom:20px}
.export-bar-label{font-size:12px;color:var(--text3)}
.feasibility-banner{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px;margin-bottom:24px;display:flex;align-items:flex-start;gap:12px}
.feasibility-banner .bi{font-size:18px;flex-shrink:0;margin-top:1px}
.feasibility-banner .bb{flex:1}
.feasibility-banner .bt{font-size:13px;font-weight:600;color:var(--text);margin-bottom:3px}
.feasibility-banner .bd{font-size:12px;color:var(--text2)}
.feasibility-banner.ok{border-left:3px solid var(--success)}
.feasibility-banner.warn{border-left:3px solid var(--accent4)}
.feasibility-banner.alert{border-left:3px solid var(--danger)}
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:12px;margin-bottom:28px}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px;animation:fadeUp .3s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.kpi-label{font-size:11px;font-weight:500;color:var(--text2);margin-bottom:6px;line-height:1.3}
.kpi-value{font-size:20px;font-weight:700;color:var(--text);letter-spacing:-.5px;margin-bottom:3px;font-family:'JetBrains Mono',monospace}
.kpi-value.accent{color:var(--accent)}.kpi-value.blue{color:var(--accent2)}.kpi-value.orange{color:var(--accent3)}.kpi-value.purple{color:var(--wd)}
.kpi-sub{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace}
.goal-results-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:12px;margin-bottom:28px}
.goal-result-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px;animation:fadeUp .35s ease both}
.goal-result-name{font-size:13px;font-weight:600;margin-bottom:12px;color:var(--text);display:flex;align-items:center;gap:7px}
.goal-color-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.goal-result-row{display:flex;justify-content:space-between;align-items:baseline;padding:5px 0;border-bottom:1px solid var(--border);gap:8px}
.goal-result-row:last-child{border-bottom:none}
.grk{font-size:12px;color:var(--text2);white-space:nowrap}
.grv{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text);font-weight:500;text-align:right}
.grv.hl{color:var(--accent);font-size:13px;font-weight:600}
.grv.lump{color:var(--accent2)}.grv.wd{color:var(--wd)}
.goal-progress-wrap{margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.goal-progress-label{display:flex;justify-content:space-between;font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--text3);margin-bottom:5px}
.goal-progress-bar-bg{height:5px;background:var(--surface3);border-radius:3px;overflow:hidden}
.goal-progress-bar-fill{height:100%;border-radius:3px;transition:width .5s ease}
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px}
@media(max-width:900px){.charts-grid{grid-template-columns:1fr}.goals-grid{grid-template-columns:1fr}}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:18px;animation:fadeUp .4s ease both}
.chart-title{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:14px;text-transform:uppercase;letter-spacing:.6px}
.chart-wrap{position:relative;height:250px}
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:28px;animation:fadeUp .45s ease both}
.table-card-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.table-card-title{font-size:12px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.6px}
.table-note{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace}
.table-overflow{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.5px;color:var(--text3);padding:9px 14px;text-align:right;border-bottom:1px solid var(--border);white-space:nowrap;background:var(--surface2)}
thead th:first-child{text-align:left}
tbody tr{border-bottom:1px solid var(--border);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
tbody td{padding:9px 14px;text-align:right;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text2);white-space:nowrap}
tbody td:first-child{text-align:left;font-family:'Inter',sans-serif;font-size:12px;color:var(--text);font-weight:500}
.total-row td{background:var(--surface3);color:var(--text)!important;font-weight:600;border-top:1px solid var(--border2)}
.total-row td:first-child{color:var(--accent)!important}
.wd-row td{background:var(--wd-bg)!important;color:var(--wd)!important}
.wd-row td:first-child{color:var(--wd)!important}
.hike-badge{display:inline-flex;align-items:center;gap:2px;padding:2px 6px;border-radius:4px;font-size:10px;font-family:'JetBrains Mono',monospace}
.hike-badge.up{background:rgba(46,160,67,.12);color:var(--success-t)}
.hike-badge.down{background:rgba(248,81,73,.1);color:var(--danger)}
.hike-badge.base{background:var(--surface3);color:var(--text3)}
.wd-badge{display:inline-flex;align-items:center;gap:2px;padding:2px 6px;border-radius:4px;font-size:10px;font-family:'JetBrains Mono',monospace;background:var(--wd-bg);color:var(--wd)}
.empty-notice{text-align:center;padding:48px 20px;color:var(--text3);font-size:13px;border:1px dashed var(--border);border-radius:10px;margin-bottom:14px}
.empty-notice .icon{font-size:28px;margin-bottom:10px;opacity:.5}
::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
footer{padding:20px 0;border-top:1px solid var(--border);text-align:center;font-size:11px;color:var(--text3);margin-top:40px}
[data-tip]{position:relative;cursor:help}
[data-tip]:hover::after{content:attr(data-tip);position:absolute;bottom:120%;left:50%;transform:translateX(-50%);background:var(--surface3);border:1px solid var(--border2);color:var(--text2);font-size:11px;font-family:'Inter',sans-serif;padding:5px 9px;border-radius:5px;white-space:nowrap;z-index:200;box-shadow:0 3px 10px var(--shadow);pointer-events:none}
</style>
</head>
<body>
<header>
  <div class="header-inner">
    <div class="brand"><div class="brand-icon">📊</div><span class="brand-name">SIP<span> Planner</span></span></div>
    <div class="header-right">
      <span class="header-sub">GOAL-BASED · INFLATION-ADJUSTED · STEP-UP · WITHDRAWALS</span>
      <button class="theme-toggle" onclick="toggleTheme()"><span id="themeIcon">🌙</span><span id="themeLabel">Dark</span></button>
    </div>
  </div>
</header>

<div class="container">
  <div class="page-header">
    <h1 class="page-title">Financial Goal Planner</h1>
    <p class="page-subtitle">Plan SIP investments with inflation adjustment, step-up strategy, lump sum, and multiple partial withdrawals per goal.</p>
  </div>

  <div class="settings-panel">
    <div class="settings-panel-title">Global Settings</div>
    <div class="settings-field">
      <div class="settings-label">Currency Symbol</div>
      <input class="settings-input" id="currencySymbol" type="text" value="₹" maxlength="4">
    </div>
    <div class="settings-divider"></div>
    <div class="settings-field">
      <div class="settings-label" data-tip="% of your monthly salary invested in SIPs">Salary Allocation %</div>
      <input class="settings-input" id="salaryPct" type="number" value="30" min="1" max="100" step="1" oninput="updateHints()">
      <div class="hint-text" id="salaryHint">30% of salary → invested monthly</div>
    </div>
    <div class="settings-field">
      <div class="settings-label" data-tip="Annual step-up % applied to SIP every year">SIP Step-Up % / Year</div>
      <input class="settings-input" id="sipGrowthRate" type="number" value="10" min="0" max="50" step="0.5" oninput="updateHints()">
      <div class="hint-text" id="sipHint">SIP grows 10% every year</div>
    </div>
    <div class="settings-field">
      <div class="settings-label" data-tip="Optional — only used for feasibility check">Current Monthly Salary (Optional)</div>
      <input class="settings-input" id="currentSalary" type="number" placeholder="e.g. 100000" oninput="updateHints()">
      <div class="settings-desc">Used only for feasibility check</div>
    </div>
  </div>

  <div class="section-header">
    <div class="section-title"><span class="dot"></span> Financial Goals</div>
    <span class="section-badge" id="goalCountBadge">0 goals</span>
  </div>
  <div class="goals-grid" id="goalsContainer">
    <div class="empty-notice" id="emptyState"><div class="icon">🎯</div>No goals yet. Add your first financial goal below.</div>
  </div>
  <div class="btn-actions">
    <button class="btn btn-ghost" onclick="addGoal()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Add Goal
    </button>
    <button class="btn btn-primary" onclick="calculate()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Calculate Plan
    </button>
    <button class="btn btn-ghost" onclick="resetAll()" style="margin-left:auto">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4"/></svg>Reset
    </button>
  </div>

  <div class="results-section" id="resultsSection">
    <div class="divider"></div>
    <div class="export-bar">
      <span class="export-bar-label">Download calculated results →</span>
      <button class="btn btn-export" onclick="exportToExcel()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Export to Excel
      </button>
    </div>
    <div id="feasibilityBanner" class="feasibility-banner ok" style="display:none">
      <div class="bi" id="bannerIcon">✅</div>
