<script>
// ==============================================================
// THEME
// ==============================================================
function toggleTheme(){
  var h=document.documentElement,dark=h.getAttribute('data-theme')==='light';
  h.setAttribute('data-theme',dark?'dark':'light');
  document.getElementById('themeIcon').textContent=dark?'☀️':'🌙';
  document.getElementById('themeLabel').textContent=dark?'Light':'Dark';
  if(document.getElementById('resultsSection').classList.contains('visible'))calculate();
}

// ==============================================================
// STATE
// ==============================================================
var goalCounter=0,wdCounters={};
var COLORS=['#2ea043','#388bfd','#f78166','#e3b341','#a78bfa','#f472b6','#34d399','#fb923c','#60a5fa','#e879f9'];
var charts={},_exp=null;

// ==============================================================
// HINTS
// ==============================================================
function updateHints(){
  var pct=parseFloat(document.getElementById('salaryPct').value)||30;
  var sal=parseFloat(document.getElementById('currentSalary').value)||0;
  var sym=document.getElementById('currencySymbol').value||'₹';
  var g=parseFloat(document.getElementById('sipGrowthRate').value)||10;
  document.getElementById('salaryHint').textContent=sal>0?pct+'% → invest '+fmt(sal*pct/100,sym)+'/mo':pct+'% of salary → invested monthly';
  document.getElementById('sipHint').textContent='SIP grows '+g+'% every year (step-up)';
}

// ==============================================================
// GOAL CARD BUILDER
// ==============================================================
function updateGoalCount(){
  var n=document.querySelectorAll('.goal-card').length;
  document.getElementById('goalCountBadge').textContent=n+' goal'+(n!==1?'s':'');
}

function toggleGoalEnabled(id){
  var card=document.getElementById('goal-'+id);
  var chk=document.getElementById('gtoggle-'+id);
  card.classList.toggle('disabled',!chk.checked);
}

function toggleOptSection(secId,chkId){
  var fields=document.getElementById(secId);
  var chk=document.getElementById(chkId);
  if(chk.checked){fields.classList.remove('hidden');}
  else{fields.classList.add('hidden');}
}

// Withdrawal counter per goal
function addWithdrawal(goalId){
  if(!wdCounters[goalId]) wdCounters[goalId]=0;
  wdCounters[goalId]++;
  var wid=wdCounters[goalId];
  var list=document.getElementById('wd-list-'+goalId);
  var item=document.createElement('div');
  item.className='wd-item';
  item.id='wd-'+goalId+'-'+wid;
  item.innerHTML=
    '<div class="wd-item-header">'+
      '<span class="wd-item-label">💸 Withdrawal #'+wid+'</span>'+
      '<button class="wd-remove-btn" onclick="removeWithdrawal('+goalId+','+wid+')">✕ Remove</button>'+
    '</div>'+
    '<div class="wd-item-fields">'+
      '<div class="field-group"><div class="wd-field-label">Withdrawal Amount (Today\'s Value)</div>'+
        '<input class="wd-input" type="number" data-wd-field="amount" placeholder="e.g. 500000"></div>'+
      '<div class="field-group"><div class="wd-field-label">At End of Year</div>'+
        '<input class="wd-input" type="number" data-wd-field="year" placeholder="e.g. 5" min="1"></div>'+
      '<div class="field-group"><div class="wd-field-label">Inflation Rate % (for this withdrawal)</div>'+
        '<input class="wd-input" type="number" data-wd-field="inflation" placeholder="e.g. 6"></div>'+
      '<div class="field-group"><div class="wd-field-label">Note / Purpose (optional)</div>'+
        '<input class="wd-input" type="text" data-wd-field="note" placeholder="e.g. Partial use"></div>'+
    '</div>';
  list.appendChild(item);
}

function removeWithdrawal(goalId,wid){
  var el=document.getElementById('wd-'+goalId+'-'+wid);
  if(el) el.remove();
}

function addGoal(p){
  goalCounter++;
  var id=goalCounter;
  wdCounters[id]=0;
  var color=COLORS[(id-1)%COLORS.length];
  var es=document.getElementById('emptyState');
  if(es) es.remove();
  p=p||{};
  var card=document.createElement('div');
  card.className='goal-card';
  card.id='goal-'+id;
  card.dataset.id=id;
  card.style.borderLeft='3px solid '+color;
  card.innerHTML=
    '<div class="goal-card-header">'+
      '<div class="goal-card-left">'+
        '<span class="goal-number">Goal '+String(id).padStart(2,'0')+'</span>'+
      '</div>'+
      '<div class="goal-card-right goal-toggle-area">'+
        '<label class="toggle-wrap" title="Enable/disable this goal">'+
          '<span class="toggle-label" style="font-size:11px">Active</span>'+
          '<span class="toggle-sw">'+
            '<input type="checkbox" id="gtoggle-'+id+'" checked onchange="toggleGoalEnabled('+id+')">'+
            '<span class="toggle-track"></span><span class="toggle-thumb"></span>'+
          '</span>'+
        '</label>'+
        '<button class="remove-btn" onclick="removeGoal('+id+')" title="Remove">✕</button>'+
      '</div>'+
    '</div>'+
    '<input class="goal-name-input" placeholder="Goal name (e.g. Retirement, Home, Education…)" value="'+(p.name||'')+'">'+
    '<div class="goal-fields">'+
      '<div class="field-group"><div class="field-label">Target Amount (Today\'s Value)</div>'+
        '<input class="field-input" type="number" data-field="target" placeholder="e.g. 5000000" value="'+(p.target||'')+'"></div>'+
      '<div class="field-group"><div class="field-label">Time Frame (Years)</div>'+
        '<input class="field-input" type="number" data-field="years" placeholder="e.g. 20" min="1" value="'+(p.years||'')+'"></div>'+
      '<div class="field-group"><div class="field-label">Expected XIRR / Return % p.a.</div>'+
        '<input class="field-input" type="number" data-field="xirr" placeholder="e.g. 12" value="'+(p.xirr||'')+'"></div>'+
      '<div class="field-group"><div class="field-label">Annual Inflation Rate %</div>'+
        '<input class="field-input" type="number" data-field="inflation" placeholder="e.g. 6" value="'+(p.inflation||'')+'"></div>'+
    '</div>'+
    // LUMP SUM
    '<div class="opt-section">'+
      '<div class="opt-section-header">'+
        '<span class="opt-section-title">💰 Lump Sum Investment</span>'+
        '<label class="toggle-wrap">'+
          '<span class="toggle-label" style="font-size:10px;color:var(--text3)">Enable</span>'+
          '<span class="toggle-sw">'+
            '<input type="checkbox" id="lump-toggle-'+id+'" onchange="toggleOptSection(\'lump-fields-'+id+'\',\'lump-toggle-'+id+'\')">'+
            '<span class="toggle-track"></span><span class="toggle-thumb"></span>'+
          '</span>'+
        '</label>'+
      '</div>'+
      '<div class="opt-fields hidden" id="lump-fields-'+id+'">'+
        '<div class="field-group"><div class="field-label">Lump Sum Amount (Today\'s Value)</div>'+
          '<input class="field-input" type="number" data-field="lumpsum" placeholder="e.g. 500000"></div>'+
        '<div class="field-group"><div class="field-label">Lump Sum Return % p.a.</div>'+
          '<input class="field-input" type="number" data-field="lumpret" placeholder="e.g. 10"></div>'+
        '<div class="opt-note">FV of lump sum is deducted from inflation-adj. target → reduces SIP needed.</div>'+
      '</div>'+
    '</div>'+
    // WITHDRAWALS
    '<div class="opt-section">'+
      '<div class="opt-section-header">'+
        '<span class="opt-section-title">💸 Partial Withdrawals</span>'+
        '<label class="toggle-wrap">'+
          '<span class="toggle-label" style="font-size:10px;color:var(--text3)">Enable</span>'+
          '<span class="toggle-sw">'+
            '<input type="checkbox" id="wd-toggle-'+id+'" onchange="toggleOptSection(\'wd-section-'+id+'\',\'wd-toggle-'+id+'\')">'+
            '<span class="toggle-track"></span><span class="toggle-thumb"></span>'+
          '</span>'+
        '</label>'+
      '</div>'+
      '<div class="opt-fields hidden" id="wd-section-'+id+'">'+
        '<div class="opt-note" style="margin-top:2px">Each withdrawal inflates to its future value by the specified year, then is added back to the required corpus — increasing SIP accordingly.</div>'+
        '<div class="wd-list" id="wd-list-'+id+'"></div>'+
        '<button class="wd-add-btn" onclick="addWithdrawal('+id+')">'+
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Add Withdrawal'+
        '</button>'+
      '</div>'+
    '</div>';
  document.getElementById('goalsContainer').appendChild(card);
  updateGoalCount();
}

function removeGoal(id){
  var el=document.getElementById('goal-'+id);
  if(el) el.remove();
  if(!document.querySelectorAll('.goal-card').length){
    var e=document.createElement('div');
    e.className='empty-notice';e.id='emptyState';
    e.innerHTML='<div class="icon">🎯</div>No goals yet. Add your first financial goal below.';
    document.getElementById('goalsContainer').appendChild(e);
  }
  updateGoalCount();
}

function resetAll(){
  document.querySelectorAll('.goal-card').forEach(function(c){c.remove();});
  var e=document.createElement('div');
  e.className='empty-notice';e.id='emptyState';
  e.innerHTML='<div class="icon">🎯</div>No goals yet. Add your first financial goal below.';
  document.getElementById('goalsContainer').appendChild(e);
  document.getElementById('resultsSection').classList.remove('visible');
  goalCounter=0;wdCounters={};_exp=null;
  updateGoalCount();
}

function getGoals(){
  return Array.from(document.querySelectorAll('.goal-card')).map(function(card,idx){
    // Extract id from card.id string ("goal-N") — never rely on dataset.id
    var id = parseInt(card.id.replace('goal-',''));

    // Read toggles by finding checkbox inputs within known child containers
    // Use querySelector scoped to the card — works regardless of id correctness
    var goalToggle  = card.querySelector('input[id^="gtoggle-"]');
    var lumpToggle  = card.querySelector('input[id^="lump-toggle-"]');
    var wdToggle    = card.querySelector('input[id^="wd-toggle-"]');

    var enabled = goalToggle ? goalToggle.checked : true;
    var lumpOn  = lumpToggle ? lumpToggle.checked : false;
    var wdOn    = wdToggle   ? wdToggle.checked   : false;

    // Always read withdrawals from .wd-item elements — gate on wdOn
    var withdrawals = [];
    if(wdOn){
      card.querySelectorAll('.wd-item').forEach(function(item){
        var amt  = parseFloat(item.querySelector('[data-wd-field="amount"]').value) || 0;
        var yr   = parseInt(item.querySelector('[data-wd-field="year"]').value)    || 0;
        var inf  = (parseFloat(item.querySelector('[data-wd-field="inflation"]').value) || 0) / 100;
        var note = item.querySelector('[data-wd-field="note"]').value || '';
        if(amt > 0 && yr > 0) withdrawals.push({amount:amt, year:yr, inflation:inf, note:note});
      });
    }

    return {
      id:       id,
      name:     card.querySelector('.goal-name-input').value.trim() || ('Goal '+(idx+1)),
      enabled:  enabled,
      target:   parseFloat(card.querySelector('[data-field="target"]').value)    || 0,
      years:    parseFloat(card.querySelector('[data-field="years"]').value)     || 0,
      xirr:    (parseFloat(card.querySelector('[data-field="xirr"]').value)     || 0) / 100,
      inflation:(parseFloat(card.querySelector('[data-field="inflation"]').value)|| 0) / 100,
      lumpOn:   lumpOn,
      lumpsum:  lumpOn ? (parseFloat(card.querySelector('[data-field="lumpsum"]').value) || 0) : 0,
      lumpret:  lumpOn ? ((parseFloat(card.querySelector('[data-field="lumpret"]').value) || 0) / 100) : 0,
      withdrawals: withdrawals,
      color: COLORS[idx % COLORS.length]
    };
  });
}

// ==============================================================
// MATHS
// ==============================================================
function calcSIP(fv,months,annualRate,annualStepUp){
  if(months<=0||fv<=0)return 0;
  var r=annualRate/12,g=annualStepUp/12;
  if(Math.abs(r-g)<1e-10)return fv/(months*Math.pow(1+r,months));
  return(fv*(r-g))/(Math.pow(1+r,months)-Math.pow(1+g,months));
}

function fmt(val,sym){
  if(isNaN(val)||val===undefined)return sym+'0';
  if(val>=1e7)return sym+(val/1e7).toFixed(2)+' Cr';
  if(val>=1e5)return sym+(val/1e5).toFixed(2)+' L';
  return sym+Math.round(val).toLocaleString('en-IN');
}

function destroyChart(k){if(charts[k]){charts[k].destroy();delete charts[k];}}

// ==============================================================
// CALCULATE
// ==============================================================
function calculate(){
  var allGoals=getGoals();
  var goals=allGoals.filter(function(g){return g.enabled;});
  if(!goals.length){alert('Please add and enable at least one goal.');return;}
  for(var i=0;i<goals.length;i++){
    if(!goals[i].target||!goals[i].years){alert('Fill in Target and Years for "'+goals[i].name+'".');return;}
  }
  var sym=document.getElementById('currencySymbol').value||'₹';
  var salaryPct=Math.max(parseFloat(document.getElementById('salaryPct').value)||30,1)/100;
  var sipGrow=Math.max(parseFloat(document.getElementById('sipGrowthRate').value)||10,0)/100;
  var curSal=parseFloat(document.getElementById('currentSalary').value)||0;
  var maxYears=Math.max.apply(null,goals.map(function(g){return g.years;}));

  // Per-goal computation
  var goalData=goals.map(function(g){
    var inflatedTarget=g.target*Math.pow(1+g.inflation,g.years);
    // Lump sum FV
    var lumpFV=g.lumpOn&&g.lumpsum>0?g.lumpsum*Math.pow(1+g.lumpret,g.years):0;
    // Withdrawal FVs — each withdrawal inflates to its year then to end-of-goal
    // The money is taken out mid-way, so we need to additionally accumulate the
    // corpus to replace it. Net effect: add back the FV of each withdrawal at goal end.
    var totalWdFV=0;
    var wdDetails=[];
    g.withdrawals.forEach(function(w){
      if(w.year>0&&w.year<=g.years){
        // FV of withdrawal amount at its withdrawal year (today's money inflated)
        var wdFVatYear=w.amount*Math.pow(1+w.inflation,w.year);
        // That money if left invested would have grown until goal end
        var remainingYears=g.years-w.year;
        var wdFVatGoal=wdFVatYear*Math.pow(1+g.xirr,remainingYears);
        totalWdFV+=wdFVatGoal;
        wdDetails.push({year:w.year,amount:w.amount,inflation:w.inflation,note:w.note,
          wdFVatYear:wdFVatYear,wdFVatGoal:wdFVatGoal});
      }
    });
    // Adjusted corpus = inflation-adj. target + withdrawal opportunity cost - lump FV
    var sipTarget=Math.max(inflatedTarget+totalWdFV-lumpFV,0);
    var months=g.years*12;
    var baseSIP=calcSIP(sipTarget,months,g.xirr,sipGrow);
    var sipByYear=[];
    for(var y=1;y<=g.years;y++) sipByYear.push(baseSIP*Math.pow(1+sipGrow,y-1));
    return Object.assign({},g,{inflatedTarget:inflatedTarget,lumpFV:lumpFV,
      totalWdFV:totalWdFV,wdDetails:wdDetails,sipTarget:sipTarget,baseSIP:baseSIP,sipByYear:sipByYear});
  });

  // Year-by-year aggregation — use IIFE to capture loop index correctly
  var yearlyData=[];
  for(var _y=1;_y<=maxYears;_y++){
    (function(yr){
      var totalSIP=0,breakdown={},wdThisYear=[];
      goalData.forEach(function(gd){
        if(yr<=gd.years){
          totalSIP+=gd.sipByYear[yr-1];
          breakdown[gd.name]=gd.sipByYear[yr-1];
        }
        gd.wdDetails.forEach(function(w){
          if(w.year===yr){
            wdThisYear.push({goal:gd.name,color:gd.color,amount:w.amount,fv:w.wdFVatYear,note:w.note});
          }
        });
      });
      var reqMon=totalSIP/salaryPct,reqAnn=reqMon*12;
      var totalWdAmt=wdThisYear.reduce(function(s,w){return s+w.fv;},0);
      yearlyData.push({year:yr,totalSIP:totalSIP,reqMon:reqMon,reqAnn:reqAnn,
        breakdown:breakdown,wdThisYear:wdThisYear,totalWdAmt:totalWdAmt});
    })(_y);
  }
  // Hike
  for(var i=0;i<yearlyData.length;i++){
    if(i===0){yearlyData[i].hikeAmt=0;yearlyData[i].hikePct=null;}
    else{
      var diff=yearlyData[i].reqAnn-yearlyData[i-1].reqAnn;
      yearlyData[i].hikeAmt=diff;
      yearlyData[i].hikePct=yearlyData[i-1].reqAnn>0?(diff/yearlyData[i-1].reqAnn)*100:0;
    }
  }

  document.getElementById('resultsSection').classList.add('visible');

  var totalBaseSIP=goalData.reduce(function(s,g){return s+g.baseSIP;},0);
  var totalGoalValue=goalData.reduce(function(s,g){return s+g.inflatedTarget;},0);
  var totalLumpFV=goalData.reduce(function(s,g){return s+g.lumpFV;},0);
  var totalWdFV=goalData.reduce(function(s,g){return s+g.totalWdFV;},0);
  var totalInvestment=yearlyData.reduce(function(s,y){return s+y.totalSIP*12;},0);
  var totalWdOutflow=yearlyData.reduce(function(s,y){return s+y.totalWdAmt;},0);
  var finalSalary=yearlyData[yearlyData.length-1].reqAnn;
  var avgHike=yearlyData.slice(1).reduce(function(s,y){return s+(y.hikePct||0);},0)/Math.max(yearlyData.length-1,1);

  _exp={sym:sym,salaryPct:salaryPct,sipGrow:sipGrow,goalData:goalData,yearlyData:yearlyData,
    totalGoalValue:totalGoalValue,totalLumpFV:totalLumpFV,totalWdFV:totalWdFV,
    totalInvestment:totalInvestment,totalWdOutflow:totalWdOutflow,
    totalBaseSIP:totalBaseSIP,finalSalary:finalSalary,avgHike:avgHike,maxYears:maxYears};

  // FEASIBILITY
  var banner=document.getElementById('feasibilityBanner');
  if(curSal>0){
    var canInvest=curSal*salaryPct,ratio=totalBaseSIP/canInvest;
    banner.style.display='flex';
    if(ratio<=0.85){banner.className='feasibility-banner ok';document.getElementById('bannerIcon').textContent='✅';
      document.getElementById('bannerTitle').textContent='Your plan looks feasible';
      document.getElementById('bannerDesc').textContent='You can invest '+fmt(canInvest,sym)+'/mo ('+( salaryPct*100).toFixed(0)+'% of '+fmt(curSal,sym)+'). Year-1 SIP is '+fmt(totalBaseSIP,sym)+'/mo — '+(ratio*100).toFixed(0)+'% of your investable surplus.';}
    else if(ratio<=1.1){banner.className='feasibility-banner warn';document.getElementById('bannerIcon').textContent='⚠️';
      document.getElementById('bannerTitle').textContent='Tight but possible';
      document.getElementById('bannerDesc').textContent='Year-1 SIP of '+fmt(totalBaseSIP,sym)+'/mo is '+(ratio*100).toFixed(0)+'% of your investable '+fmt(canInvest,sym)+'/mo.';}
    else{banner.className='feasibility-banner alert';document.getElementById('bannerIcon').textContent='🚨';
      document.getElementById('bannerTitle').textContent='SIP exceeds investable salary';
      document.getElementById('bannerDesc').textContent='Need at least '+fmt(yearlyData[0].reqMon,sym)+'/mo salary to execute this plan.';}
  } else { banner.style.display='none'; }

  // KPIs
  document.getElementById('kpiGrid').innerHTML=
    '<div class="kpi-card"><div class="kpi-label">Total Monthly SIP (Year 1)</div><div class="kpi-value accent">'+fmt(totalBaseSIP,sym)+'</div><div class="kpi-sub">'+goals.length+' active goal'+(goals.length>1?'s':'')+'</div></div>'+
    '<div class="kpi-card"><div class="kpi-label">Inflation-Adj. Corpus</div><div class="kpi-value">'+fmt(totalGoalValue,sym)+'</div><div class="kpi-sub">total future-value target</div></div>'+
    (totalLumpFV>0?'<div class="kpi-card"><div class="kpi-label">Lump Sum Contribution (FV)</div><div class="kpi-value blue">'+fmt(totalLumpFV,sym)+'</div><div class="kpi-sub">reduces SIP requirement</div></div>':'')+
    (totalWdFV>0?'<div class="kpi-card"><div class="kpi-label">Total Withdrawal Impact (FV)</div><div class="kpi-value purple">'+fmt(totalWdFV,sym)+'</div><div class="kpi-sub">added to required corpus</div></div>':'')+
    (totalWdOutflow>0?'<div class="kpi-card"><div class="kpi-label">Total Withdrawal Outflow</div><div class="kpi-value purple">'+fmt(totalWdOutflow,sym)+'</div><div class="kpi-sub">actual FV at withdrawal years</div></div>':'')+
    '<div class="kpi-card"><div class="kpi-label">Required Salary — Year 1</div><div class="kpi-value blue">'+fmt(yearlyData[0].reqMon,sym)+'/mo</div><div class="kpi-sub">'+fmt(yearlyData[0].reqAnn,sym)+' p.a. · '+(salaryPct*100).toFixed(0)+'% alloc.</div></div>'+
    '<div class="kpi-card"><div class="kpi-label">Required Salary — Final Year</div><div class="kpi-value blue">'+fmt(finalSalary/12,sym)+'/mo</div><div class="kpi-sub">Year '+maxYears+'</div></div>'+
    '<div class="kpi-card"><div class="kpi-label">Avg. Salary Hike Needed</div><div class="kpi-value orange">'+avgHike.toFixed(1)+'%</div><div class="kpi-sub">per year to stay on plan</div></div>'+
    '<div class="kpi-card"><div class="kpi-label">Total SIP Invested (Nominal)</div><div class="kpi-value">'+fmt(totalInvestment,sym)+'</div><div class="kpi-sub">step-up: '+(sipGrow*100).toFixed(1)+'% p.a.</div></div>';

  // PER-GOAL CARDS
