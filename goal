// EXCEL EXPORT  — pure JS XLSX (no external library)
// ==============================================================
function exportToExcel(){
  if(!_exp){alert('Please run Calculate Plan first.');return;}
  var D=_exp,sym=D.sym,r2=function(v){return Math.round(v*100)/100;};
  var goalNames=D.goalData.map(function(g){return g.name;});

  // Sheet 1: Summary
  var s1=[
    ['SIP Goal Planner — Summary Report'],
    ['Generated',new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})],
    [],
    ['GLOBAL SETTINGS'],
    ['Currency',sym],['Salary Allocation %',r2(D.salaryPct*100)],['SIP Step-Up % p.a.',r2(D.sipGrow*100)],
    [],['KEY METRICS'],
    ['Total Monthly SIP Year-1 ('+sym+')',r2(D.totalBaseSIP)],
    ['Inflation-Adj. Corpus ('+sym+')',r2(D.totalGoalValue)],
    ['Lump Sum FV Contribution ('+sym+')',r2(D.totalLumpFV)],
    ['Withdrawal FV Impact ('+sym+')',r2(D.totalWdFV)],
    ['Total SIP Invested Nominal ('+sym+')',r2(D.totalInvestment)],
    ['Total Withdrawal Outflow ('+sym+')',r2(D.totalWdOutflow)],
    ['Req. Monthly Salary Year-1 ('+sym+')',r2(D.yearlyData[0].reqMon)],
    ['Req. Annual Salary Year-1 ('+sym+')',r2(D.yearlyData[0].reqAnn)],
    ['Req. Monthly Salary Final Year ('+sym+')',r2(D.yearlyData[D.yearlyData.length-1].reqMon)],
    ['Req. Annual Salary Final Year ('+sym+')',r2(D.finalSalary)],
    ['Avg Salary Hike Needed %',r2(D.avgHike)],
    [],['PER-GOAL BREAKDOWN'],
    ['Goal','Target (Today)','Years','XIRR %','Inflation %','Infl-Adj Corpus','Lump Sum','Lump FV','Wd FV Impact','SIP Target','Year-1 SIP/mo','Final SIP/mo']
  ];
  D.goalData.forEach(function(g){
    s1.push([g.name,r2(g.target),g.years,r2(g.xirr*100),r2(g.inflation*100),
      r2(g.inflatedTarget),r2(g.lumpsum||0),r2(g.lumpFV||0),r2(g.totalWdFV||0),
      r2(g.sipTarget),r2(g.baseSIP),r2(g.sipByYear[g.sipByYear.length-1])]);
  });

  // Sheet 2: Year-by-Year
  var h2=['Year'];
  D.goalData.forEach(function(g){h2.push(g.name+' SIP/mo',g.name+' Annual SIP');});
  h2.push('Total SIP/mo','Total Annual SIP','Monthly Salary','Annual Salary','Hike Amount','Hike %','Withdrawal Detail');
  var s2=[h2];
  D.yearlyData.forEach(function(y){
    var row=['Year '+y.year];
    D.goalData.forEach(function(g){
      var sipMo=y.breakdown[g.name]||0;
      row.push(r2(sipMo),r2(sipMo*12));
    });
    row.push(r2(y.totalSIP),r2(y.totalSIP*12),r2(y.reqMon),r2(y.reqAnn),
      y.hikePct===null?'':r2(y.hikeAmt),
      y.hikePct===null?'Base':r2(y.hikePct),
      y.wdThisYear.length?y.wdThisYear.map(function(w){
        return (w.note||w.goal)+': FV='+r2(w.fv);
      }).join('; '):'');
    s2.push(row);
    // If any withdrawal this year, add a detail row
    if(y.wdThisYear.length){
      y.wdThisYear.forEach(function(w){
        var detailRow=['  ↳ WD: '+w.goal+(w.note?' ('+w.note+')':'')];
        D.goalData.forEach(function(){detailRow.push('','');});
        detailRow.push('','','','','','','Amount FV: '+r2(w.fv));
        s2.push(detailRow);
      });
    }
  });
  var tot=['Total/Final'];
  D.goalData.forEach(function(g){
    var last=0;
    for(var i=D.yearlyData.length-1;i>=0;i--){if(D.yearlyData[i].breakdown[g.name]){last=D.yearlyData[i].breakdown[g.name];break;}}
    tot.push(r2(last),r2(last*12));
  });
  tot.push(r2(D.yearlyData[D.yearlyData.length-1].totalSIP),
    r2(D.yearlyData[D.yearlyData.length-1].totalSIP*12),
    r2(D.yearlyData[D.yearlyData.length-1].reqMon),r2(D.finalSalary),
    '','','Total Outflow: '+r2(D.totalWdOutflow));
  s2.push(tot);

  // Sheet 3: Per-Goal Schedule (with Annual SIP + Withdrawal columns)
  var h3=['Year'];
  D.goalData.forEach(function(g){h3.push(g.name+' Infl-Adj Target',g.name+' SIP/mo',g.name+' Annual SIP',g.name+' Withdrawal FV');});
  var s3=[h3];
  for(var yr=1;yr<=D.maxYears;yr++){
    var row3=['Year '+yr];
    D.goalData.forEach(function(gd){
      if(yr<=gd.years){
        var adjTarget=gd.target*Math.pow(1+gd.inflation,yr);
        var sipMo=gd.sipByYear[yr-1];
        var wdThisYr=gd.wdDetails.filter(function(w){return w.year===yr;});
        var wdStr=wdThisYr.length?wdThisYr.map(function(w){return r2(w.wdFVatYear);}).join('+'):'';
        row3.push(r2(adjTarget),r2(sipMo),r2(sipMo*12),wdStr||'');
      } else {row3.push('Done','—','—','');}
    });
    s3.push(row3);
  }

  // Sheet 4: Withdrawals Detail
  var s4=[['Goal','Withdrawal Year','Amount Today ('+sym+')','Inflation %','FV at Wd Year ('+sym+')','FV at Goal End ('+sym+')','Note']];
  D.goalData.forEach(function(g){
    g.wdDetails.forEach(function(w){
      s4.push([g.name,w.year,r2(w.amount),r2(w.inflation*100),r2(w.wdFVatYear),r2(w.wdFVatGoal),w.note||'']);
    });
  });
  if(s4.length===1) s4.push(['No withdrawals defined','','','','','','']);

  buildXLSX([
    {name:'Summary',data:s1},
    {name:'Year-by-Year Schedule',data:s2},
    {name:'Per-Goal SIP Schedule',data:s3},
    {name:'Withdrawals Detail',data:s4}
  ],'SIP_Goal_Plan_'+new Date().toISOString().slice(0,10)+'.xlsx');
}

// ==============================================================
// PURE JS XLSX BUILDER
// Produces a valid Office Open XML .xlsx (ZIP + XML)
// ==============================================================
function buildXLSX(sheets,filename){
  // --- string escaping ---
  function xe(s){
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&apos;');
  }
  // --- col index → letter(s) ---
  function col(n){
    var s='';n++;
    while(n>0){n--;s=String.fromCharCode(65+(n%26))+s;n=Math.floor(n/26);}
    return s;
  }
  // --- shared strings ---
  var sstArr=[],sstMap={};
  function si(s){
    var k=String(s);
    if(sstMap[k]===undefined){sstMap[k]=sstArr.length;sstArr.push(k);}
    return sstMap[k];
  }
  // pre-scan all string cells
  sheets.forEach(function(sh){
    sh.data.forEach(function(row){
      if(!row)return;
      row.forEach(function(c){if(typeof c==='string'&&c!=='')si(c);});
    });
  });
  // --- worksheet XML ---
  function wsXML(data){
    var x='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>';
    x+='<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetData>';
    data.forEach(function(row,ri){
      if(!row||!row.length)return;
      x+='<row r="'+(ri+1)+'">';
      row.forEach(function(c,ci){
        var addr=col(ci)+(ri+1);
        if(c===null||c===undefined||c===''){x+='<c r="'+addr+'"/>';}
        else if(typeof c==='number'){x+='<c r="'+addr+'" t="n"><v>'+c+'</v></c>';}
        else{x+='<c r="'+addr+'" t="s"><v>'+si(String(c))+'</v></c>';}
      });
      x+='</row>';
    });
    x+='</sheetData></worksheet>';
    return x;
  }
  // --- shared strings XML ---
  function sstXML(){
    var x='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>';
    x+='<sst xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" count="'+sstArr.length+'" uniqueCount="'+sstArr.length+'">';
    sstArr.forEach(function(s){x+='<si><t xml:space="preserve">'+xe(s)+'</t></si>';});
    x+='</sst>';return x;
  }
  // --- workbook XML ---
  function wbXML(){
    var x='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>';
    x+='<workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><sheets>';
    sheets.forEach(function(sh,i){x+='<sheet name="'+xe(sh.name)+'" sheetId="'+(i+1)+'" r:id="rId'+(i+1)+'"/>';});
    x+='</sheets></workbook>';return x;
  }
  // --- workbook rels ---
  function wbRels(){
    var x='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>';
    x+='<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">';
    sheets.forEach(function(sh,i){
      x+='<Relationship Id="rId'+(i+1)+'" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet'+(i+1)+'.xml"/>';
    });
    x+='<Relationship Id="rId'+(sheets.length+1)+'" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/sharedStrings" Target="sharedStrings.xml"/>';
    x+='</Relationships>';return x;
  }
  // --- content types ---
  function ctXML(){
    var x='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>';
    x+='<Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types">';
    x+='<Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/>';
    x+='<Default Extension="xml" ContentType="application/xml"/>';
    x+='<Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>';
    sheets.forEach(function(sh,i){
      x+='<Override PartName="/xl/worksheets/sheet'+(i+1)+'.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>';
    });
    x+='<Override PartName="/xl/sharedStrings.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sharedStrings+xml"/>';
    x+='</Types>';return x;
  }
  var dotRels='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'+
    '<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">'+
    '<Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/>'+
    '</Relationships>';

  // =========================================================
  // ZIP writer — fixed byte layout
  // =========================================================
  function strToBytes(str){
    var buf=[],i=0;
    for(;i<str.length;i++){
      var c=str.charCodeAt(i);
      if(c<0x80){buf.push(c);}
      else if(c<0x800){buf.push(0xC0|(c>>6),0x80|(c&0x3F));}
      else{buf.push(0xE0|(c>>12),0x80|((c>>6)&0x3F),0x80|(c&0x3F));}
    }
    return new Uint8Array(buf);
  }

  function crc32(data){
    var tbl=crc32._t;
    if(!tbl){
      tbl=new Uint32Array(256);
      for(var n=0;n<256;n++){
        var c=n;
        for(var k=0;k<8;k++) c=c&1?(0xEDB88320^(c>>>1)):(c>>>1);
        tbl[n]=c;
      }
      crc32._t=tbl;
    }
    var crc=0xFFFFFFFF;
    for(var i=0;i<data.length;i++) crc=tbl[(crc^data[i])&0xFF]^(crc>>>8);
    return (crc^0xFFFFFFFF)>>>0;
  }

  // Write a 4-byte little-endian uint32 into a DataView
  function w32(dv,off,val){dv.setUint32(off,val,true);}
  function w16(dv,off,val){dv.setUint16(off,val,true);}

  function makeEntry(name,content){
    var nb=strToBytes(name);
    var db=typeof content==='string'?strToBytes(content):content;
    var crc=crc32(db);
    // Local file header = 30 bytes + name
    var lhSize=30+nb.length;
    var lhBuf=new ArrayBuffer(lhSize);
    var lh=new DataView(lhBuf);
    lh.setUint32(0,0x04034B50,true);  // sig
    w16(lh,4,20);    // version needed
    w16(lh,6,0);     // flags
    w16(lh,8,0);     // compression: stored
    w16(lh,10,0);    // mod time
    w16(lh,12,0);    // mod date
    w32(lh,14,crc);
    w32(lh,18,db.length);
    w32(lh,22,db.length);
    w16(lh,26,nb.length);
    w16(lh,28,0);    // extra field len
    var lhBytes=new Uint8Array(lhBuf);
    lhBytes.set(nb,30);
    return{name:nb,data:db,crc:crc,lhBytes:lhBytes,size:db.length};
  }

  function buildZip(entries){
    // Calculate total size
    var localSize=0;
    entries.forEach(function(e){localSize+=e.lhBytes.length+e.data.length;});
    var cdEntrySize=entries.reduce(function(s,e){return s+46+e.name.length;},0);
    var totalSize=localSize+cdEntrySize+22;

    var buf=new ArrayBuffer(totalSize);
    var view=new DataView(buf);
    var bytes=new Uint8Array(buf);
    var pos=0,offsets=[];

    // Write local file entries
    entries.forEach(function(e){
      offsets.push(pos);
      bytes.set(e.lhBytes,pos); pos+=e.lhBytes.length;
      bytes.set(e.data,pos);    pos+=e.data.length;
    });

    // Write central directory
    var cdStart=pos;
    entries.forEach(function(e,i){
      view.setUint32(pos,0x02014B50,true);  // sig
      view.setUint16(pos+4,20,true);   // version made
      view.setUint16(pos+6,20,true);   // version needed
      view.setUint16(pos+8,0,true);    // flags
      view.setUint16(pos+10,0,true);   // compression
      view.setUint16(pos+12,0,true);   // mod time
      view.setUint16(pos+14,0,true);   // mod date
      view.setUint32(pos+16,e.crc,true);
      view.setUint32(pos+20,e.size,true);
      view.setUint32(pos+24,e.size,true);
      view.setUint16(pos+28,e.name.length,true);
      view.setUint16(pos+30,0,true);   // extra
      view.setUint16(pos+32,0,true);   // comment
      view.setUint16(pos+34,0,true);   // disk start
      view.setUint16(pos+36,0,true);   // int attrib
      view.setUint32(pos+38,0,true);   // ext attrib
      view.setUint32(pos+42,offsets[i],true); // local header offset
      pos+=46;
      bytes.set(e.name,pos); pos+=e.name.length;
    });

    // End of central directory
    var cdSize=pos-cdStart;
    view.setUint32(pos,0x06054B50,true);  // sig
    view.setUint16(pos+4,0,true);  // disk num
    view.setUint16(pos+6,0,true);  // start disk
    view.setUint16(pos+8,entries.length,true);
    view.setUint16(pos+10,entries.length,true);
    view.setUint32(pos+12,cdSize,true);
    view.setUint32(pos+16,cdStart,true);
    view.setUint16(pos+20,0,true);

    return new Uint8Array(buf);
  }

  // Assemble all XML files into ZIP entries
  var entries=[];
  entries.push(makeEntry('[Content_Types].xml', ctXML()));
  entries.push(makeEntry('_rels/.rels', dotRels));
  entries.push(makeEntry('xl/workbook.xml', wbXML()));
  entries.push(makeEntry('xl/_rels/workbook.xml.rels', wbRels()));
  sheets.forEach(function(sh,i){
    entries.push(makeEntry('xl/worksheets/sheet'+(i+1)+'.xml', wsXML(sh.data)));
  });
  entries.push(makeEntry('xl/sharedStrings.xml', sstXML()));

  var zip=buildZip(entries);
  var blob=new Blob([zip],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;a.download=filename;
  document.body.appendChild(a);a.click();
  setTimeout(function(){URL.revokeObjectURL(url);a.remove();},2000);
}

