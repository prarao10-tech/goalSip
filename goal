  // Totals row
  var totalCols=goalData.length*2+8;
  tbRows+='<tr class="total-row"><td>Total / Final</td>';
  goalData.forEach(function(gd){
    var lastSipMo=0;
    for(var i=yearlyData.length-1;i>=0;i--){
      if(yearlyData[i].breakdown[gd.name]){lastSipMo=yearlyData[i].breakdown[gd.name];break;}
    }
    tbRows+='<td>'+fmt(lastSipMo,sym)+'/mo</td><td>'+fmt(lastSipMo*12,sym)+'/yr</td>';
  });
  tbRows+='<td>'+fmt(yearlyData[yearlyData.length-1].totalSIP,sym)+'/mo</td>';
  tbRows+='<td>'+fmt(yearlyData[yearlyData.length-1].totalSIP*12,sym)+'/yr</td>';
  tbRows+='<td>'+fmt(yearlyData[yearlyData.length-1].reqMon,sym)+'/mo</td>';
  tbRows+='<td>'+fmt(finalSalary,sym)+' p.a.</td>';
  tbRows+='<td colspan="2">Total Invested: '+fmt(totalInvestment,sym)+'</td>';
  tbRows+='<td style="text-align:left">Total Outflow: '+fmt(totalWdOutflow,sym)+'</td></tr>';
  tb.innerHTML=tbRows;

  // ── TABLE 2 : Per-Goal SIP Schedule ──────────────────────────────────
  // Columns: Year | [Infl-Adj Target | SIP/mo | Annual SIP | Withdrawal?] x goal
  var gth=document.querySelector('#goalTable thead');
  var gtb=document.querySelector('#goalTable tbody');

  var gh1='<tr><th rowspan="2">Year</th>';
  goalData.forEach(function(g){
    gh1+='<th colspan="4" style="color:'+g.color+';border-bottom:none">'+g.name+'</th>';
  });
  gh1+='</tr>';
  var gh2='<tr>';
  goalData.forEach(function(){
    gh2+='<th>Infl-Adj Target</th><th>SIP/mo</th><th>Annual SIP</th><th>Withdrawal</th>';
  });
  gh2+='</tr>';
  gth.innerHTML=gh1+gh2;

  var gr='';
  for(var yr=1;yr<=maxYears;yr++){
    // collect withdrawals this year per goal
    var wdByGoal={};
    goalData.forEach(function(gd){
      gd.wdDetails.forEach(function(w){
        if(w.year===yr){
          if(!wdByGoal[gd.name]) wdByGoal[gd.name]=[];
          wdByGoal[gd.name].push(w);
        }
      });
    });

    gr+='<tr><td>Year '+yr+'</td>';
    goalData.forEach(function(gd){
      if(yr<=gd.years){
        var adjTarget=gd.target*Math.pow(1+gd.inflation,yr);
        var sipMo=gd.sipByYear[yr-1];
        var sipAnn=sipMo*12;
        var wds=wdByGoal[gd.name];
        var wdCell2=wds&&wds.length
          ?wds.map(function(w){return '<span class="wd-badge" title="'+(w.note||'')+'">'+fmt(w.wdFVatYear,sym)+'</span>';}).join('')
          :'—';
        gr+='<td>'+fmt(adjTarget,sym)+'</td>'+
            '<td style="color:'+gd.color+';font-weight:600">'+fmt(sipMo,sym)+'</td>'+
            '<td style="color:'+gd.color+';font-weight:500">'+fmt(sipAnn,sym)+'</td>'+
            '<td style="text-align:left">'+wdCell2+'</td>';
      } else {
        gr+='<td style="color:var(--text3);font-style:italic">Completed</td>'+
            '<td style="color:var(--text3)">—</td>'+
            '<td style="color:var(--text3)">—</td>'+
            '<td>—</td>';
      }
    });
    gr+='</tr>';

    // Full-width withdrawal highlight row (only when ≥1 withdrawal across any goal this year)
    var anyWd=Object.keys(wdByGoal).length>0;
    if(anyWd){
      var totalGoalCols=goalData.length*4+1;
      gr+='<tr class="wd-row">'+
        '<td colspan="'+totalGoalCols+'" style="text-align:left;padding:6px 16px;font-size:11px;border-left:3px solid var(--wd)">'+
        '<strong style="color:var(--wd)">💸 Year '+yr+' Withdrawals:</strong> '+
        Object.keys(wdByGoal).map(function(gname){
          return wdByGoal[gname].map(function(w){
            return '<span style="margin-right:14px"><strong>'+gname+'</strong>'+(w.note?' ('+w.note+')':'')+
              ' — Today\'s value: <strong>'+fmt(w.amount,sym)+'</strong>'+
              ' → FV: <strong>'+fmt(w.wdFVatYear,sym)+'</strong>'+
              ' | Corpus impact: <strong style="color:var(--wd)">'+fmt(w.wdFVatGoal,sym)+'</strong></span>';
          }).join('');
        }).join('')+
        '</td></tr>';
    }
  }
  gtb.innerHTML=gr;

  document.getElementById('resultsSection').scrollIntoView({behavior:'smooth',block:'start'});
}

// ==============================================================
// CHART OPTIONS
// ==============================================================
function copts(sym,gc,tc,tbg,tbr,lc){
  return{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
    plugins:{legend:{labels:{color:lc,font:{family:'Inter',size:11},padding:10,boxWidth:10,usePointStyle:true,pointStyleWidth:8}},
      tooltip:{backgroundColor:tbg,borderColor:tbr,borderWidth:1,titleColor:'#1f2328',bodyColor:'#636c76',
        titleFont:{family:'Inter',size:12,weight:'600'},bodyFont:{family:'JetBrains Mono',size:11},padding:10,
        callbacks:{label:function(ctx){var v=ctx.raw;
          if(v>=1e7)return ' '+ctx.dataset.label+': '+sym+(v/1e7).toFixed(2)+' Cr';
          if(v>=1e5)return ' '+ctx.dataset.label+': '+sym+(v/1e5).toFixed(2)+' L';
          return ' '+ctx.dataset.label+': '+sym+Math.round(v).toLocaleString('en-IN');}}}},
    scales:{
      x:{grid:{color:gc},ticks:{color:tc,font:{family:'JetBrains Mono',size:9}}},
      y:{grid:{color:gc},ticks:{color:tc,font:{family:'JetBrains Mono',size:9},callback:function(v){
        if(v>=1e7)return sym+(v/1e7).toFixed(1)+'Cr';
        if(v>=1e5)return sym+(v/1e5).toFixed(1)+'L';
        if(v>=1e3)return sym+(v/1e3).toFixed(0)+'K';
        return sym+v;}}}}};
}

